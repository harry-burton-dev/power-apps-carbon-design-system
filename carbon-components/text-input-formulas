CarbonInputType := Type({
    Height:                  Number,
    FontSize:                Number,
    PaddingH:                Number,
    LabelLayout:             Text,
    DisplayMode:             Text,
    ValidationState:         Text,
    Fill:                    Color,
    HoverFill:               Color,
    DisabledFill:            Color,
    Color:                   Color,
    HoverColor:              Color,
    DisabledColor:           Color,
    BorderColor:             Color,
    BorderThickness:         Number,
    HoverBorderColor:        Color,
    FocusedBorderColor:      Color,
    FocusedBorderThickness:  Number,
    DisabledBorderColor:     Color,
    LabelColor:              Color,
    HelperColor:             Color
});
CarbonInputStyles := Table(
    { Style: "Default", LabelLayout: "Above",  FluidHeight: 0                   },
    { Style: "Fluid",   LabelLayout: "Inside", FluidHeight: CarbonContainer.C05 }
);
CarbonInputSizes := Table(
    { Size: "sm", Height: CarbonContainer.C02, FontSize: 14, PaddingH: CarbonSpacing.S05 },
    { Size: "md", Height: CarbonContainer.C03, FontSize: 14, PaddingH: CarbonSpacing.S05 },
    { Size: "lg", Height: CarbonContainer.C04, FontSize: 16, PaddingH: CarbonSpacing.S05 }
);
CarbonInputStates := Table(
    { State: "Default",
      DisplayMode:            DisplayMode.Edit,
      ValidationState:        "None",
      Fill:                   ColorValue(Theme.Active.Layer01),
      HoverFill:              ColorValue(Theme.Active.Layer01Hover),
      DisabledFill:           ColorValue(Theme.Active.Layer01),
      Color:                  ColorValue(Theme.Active.TextPrimary),
      HoverColor:             ColorValue(Theme.Active.TextPrimary),
      DisabledColor:          ColorValue(Theme.Active.TextDisabled),
      BorderColor:            ColorValue(Theme.Active.Border),
      BorderThickness:        1,
      HoverBorderColor:       ColorValue(Theme.Active.BorderHover),
      FocusedBorderColor:     ColorValue(Theme.Active.FocusBorder),
      FocusedBorderThickness: 2,
      DisabledBorderColor:    ColorValue(Theme.Active.Border),
      LabelColor:             ColorValue(Theme.Active.TextSecondary),
      HelperColor:            ColorValue(Theme.Active.TextSecondary) },
    { State: "Disabled",
      DisplayMode:            DisplayMode.Disabled,
      ValidationState:        "None",
      Fill:                   ColorValue(Theme.Active.Layer01),
      HoverFill:              ColorValue(Theme.Active.Layer01),
      DisabledFill:           ColorValue(Theme.Active.Layer01),
      Color:                  ColorValue(Theme.Active.TextDisabled),
      HoverColor:             ColorValue(Theme.Active.TextDisabled),
      DisabledColor:          ColorValue(Theme.Active.TextDisabled),
      BorderColor:            ColorValue(Theme.Active.Border),
      BorderThickness:        1,
      HoverBorderColor:       ColorValue(Theme.Active.Border),
      FocusedBorderColor:     ColorValue(Theme.Active.Border),
      FocusedBorderThickness: 1,
      DisabledBorderColor:    ColorValue(Theme.Active.Border),
      LabelColor:             ColorValue(Theme.Active.TextDisabled),
      HelperColor:            ColorValue(Theme.Active.TextDisabled) },
    { State: "ReadOnly",
      DisplayMode:            DisplayMode.View,
      ValidationState:        "None",
      Fill:                   RGBA(0,0,0,0),
      HoverFill:              RGBA(0,0,0,0),
      DisabledFill:           RGBA(0,0,0,0),
      Color:                  ColorValue(Theme.Active.TextPrimary),
      HoverColor:             ColorValue(Theme.Active.TextPrimary),
      DisabledColor:          ColorValue(Theme.Active.TextPrimary),
      BorderColor:            RGBA(0,0,0,0),
      BorderThickness:        1,
      HoverBorderColor:       RGBA(0,0,0,0),
      FocusedBorderColor:     RGBA(0,0,0,0),
      FocusedBorderThickness: 1,
      DisabledBorderColor:    RGBA(0,0,0,0),
      LabelColor:             ColorValue(Theme.Active.TextSecondary),
      HelperColor:            ColorValue(Theme.Active.TextSecondary) },
    { State: "Error",
      DisplayMode:            DisplayMode.Edit,
      ValidationState:        "Error",
      Fill:                   ColorValue(Theme.Active.Layer01),
      HoverFill:              ColorValue(Theme.Active.Layer01Hover),
      DisabledFill:           ColorValue(Theme.Active.Layer01),
      Color:                  ColorValue(Theme.Active.TextPrimary),
      HoverColor:             ColorValue(Theme.Active.TextPrimary),
      DisabledColor:          ColorValue(Theme.Active.TextDisabled),
      BorderColor:            ColorValue(Theme.Active.Danger),
      BorderThickness:        2,
      HoverBorderColor:       ColorValue(Theme.Active.Danger),
      FocusedBorderColor:     ColorValue(Theme.Active.Danger),
      FocusedBorderThickness: 2,
      DisabledBorderColor:    ColorValue(Theme.Active.Danger),
      LabelColor:             ColorValue(Theme.Active.TextSecondary),
      HelperColor:            ColorValue(Theme.Active.TextError) },
    { State: "Warning",
      DisplayMode:            DisplayMode.Edit,
      ValidationState:        "None",
      Fill:                   ColorValue(Theme.Active.Layer01),
      HoverFill:              ColorValue(Theme.Active.Layer01Hover),
      DisabledFill:           ColorValue(Theme.Active.Layer01),
      Color:                  ColorValue(Theme.Active.TextPrimary),
      HoverColor:             ColorValue(Theme.Active.TextPrimary),
      DisabledColor:          ColorValue(Theme.Active.TextDisabled),
      BorderColor:            ColorValue(Theme.Active.Warning),
      BorderThickness:        2,
      HoverBorderColor:       ColorValue(Theme.Active.Warning),
      FocusedBorderColor:     ColorValue(Theme.Active.Warning),
      FocusedBorderThickness: 2,
      DisabledBorderColor:    ColorValue(Theme.Active.Warning),
      LabelColor:             ColorValue(Theme.Active.TextSecondary),
      HelperColor:            ColorValue(Theme.Active.Warning) }
);
CarbonInput(style: Text, size: Text, state: Text) : CarbonInputType =
    With(
        {
            sty: LookUp(CarbonInputStyles, Style = style),
            sz:  LookUp(CarbonInputSizes,  Size  = size),
            st:  LookUp(CarbonInputStates, State = state)
        },
        {
            Height:                  If(sty.FluidHeight > 0, sty.FluidHeight, sz.Height),
            FontSize:                sz.FontSize,
            PaddingH:                sz.PaddingH,
            LabelLayout:             sty.LabelLayout,
            DisplayMode:             st.DisplayMode,
            ValidationState:         st.ValidationState,
            Fill:                    st.Fill,
            HoverFill:               st.HoverFill,
            DisabledFill:            st.DisabledFill,
            Color:                   st.Color,
            HoverColor:              st.HoverColor,
            DisabledColor:           st.DisabledColor,
            BorderColor:             st.BorderColor,
            BorderThickness:         st.BorderThickness,
            HoverBorderColor:        st.HoverBorderColor,
            FocusedBorderColor:      st.FocusedBorderColor,
            FocusedBorderThickness:  st.FocusedBorderThickness,
            DisabledBorderColor:     st.DisabledBorderColor,
            LabelColor:              st.LabelColor,
            HelperColor:             st.HelperColor
        }
    );
